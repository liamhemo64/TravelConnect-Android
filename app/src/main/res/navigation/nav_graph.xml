<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/apk/res/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.idz.travelconnect.features.auth.LoginFragment"
        android:label="Login">
        
        <action
            android:id="@+id/action_loginFragment_to_feedFragment"
            app:destination="@id/feedFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
            
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
    </fragment>
    
    <!-- Using SafeArgs to pass email as a parameter -->
    <fragment
        android:id="@+id/feedFragment"
        android:name="com.idz.travelconnect.features.feed.FeedFragment"
        android:label="Feed" >
        <argument
            android:name="userEmail"
            app:argType="string" />
    </fragment>

    <fragment 
        android:id="@+id/registerFragment"
        android:name="com.idz.travelconnect.features.auth.RegisterFragment"
        android:label="Register"/>
</navigation>
