<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- Global Action for Post Details -->
    <action
        android:id="@+id/action_global_postDetailFragment"
        app:destination="@id/postDetailFragment" />

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.idz.travelconnect.features.auth.LoginFragment"
        android:label="Login">
        <action
            android:id="@+id/action_loginFragment_to_feedFragment"
            app:destination="@id/feedFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
    </fragment>

    <fragment
        android:id="@+id/feedFragment"
        android:name="com.idz.travelconnect.features.feed.FeedFragment"
        android:label="Home">
        <argument
            android:name="userEmail"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.idz.travelconnect.features.auth.RegisterFragment"
        android:label="Register">
        <action
            android:id="@+id/action_registerFragment_to_feedFragment"
            app:destination="@id/feedFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/aiAssistantFragment"
        android:name="com.idz.travelconnect.features.ai.AiAssistantFragment"
        android:label="AI Assistant" />

    <fragment
        android:id="@+id/postFragment"
        android:name="com.idz.travelconnect.features.post.PostFragment"
        android:label="Post">
        <argument
            android:name="postId"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.idz.travelconnect.features.profile.ProfileFragment"
        android:label="Profile" />

    <fragment
        android:id="@+id/postDetailFragment"
        android:name="com.idz.travelconnect.features.postdetail.PostDetailFragment"
        android:label="Post Detail">
        <argument
            android:name="postId"
            app:argType="string" />
        <action
            android:id="@+id/action_postDetailFragment_to_editPostFragment"
            app:destination="@id/editPostFragment" />
    </fragment>

    <fragment
        android:id="@+id/editPostFragment"
        android:name="com.idz.travelconnect.features.editpost.EditPostFragment"
        android:label="Edit Post">
        <argument
            android:name="postId"
            app:argType="string" />
    </fragment>

    <!-- Generic Post List Fragment (not navigated to directly, but hosted) -->
    <fragment
        android:id="@+id/postListFragment"
        android:name="com.idz.travelconnect.features.posts.PostListFragment"
        android:label="Posts">
        <argument
            android:name="userId"
            app:argType="string"
            android:defaultValue="@null"
            app:nullable="true" />
    </fragment>

</navigation>
