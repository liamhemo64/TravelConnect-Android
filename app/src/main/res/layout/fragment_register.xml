<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@android:color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="48dp">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/register_glStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_begin="24dp" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/register_glEnd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_end="24dp" />

        <!-- Top Image / Header -->
        <ImageView
            android:id="@+id/register_ivHeaderBg"
            android:layout_width="0dp"
            android:layout_height="250dp"
            android:scaleType="centerCrop"
            android:src="@drawable/bg_login" 
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/register_ivLogo"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_airplane"
            android:background="@drawable/bg_circle_logo"
            android:padding="20dp"
            android:elevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/register_ivHeaderBg"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="-40dp"/>

        <TextView
            android:id="@+id/register_tvAppTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textSize="22sp"
            android:textColor="#007ACC"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/register_ivLogo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/register_tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Join TravelConnect today"
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/register_tvAppTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Display Name Field -->
        <TextView
            android:id="@+id/register_tvNameLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Display Name"
            android:textColor="#424242"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/register_tvSubtitle"
            app:layout_constraintStart_toStartOf="@id/register_glStart" />

        <EditText
            android:id="@+id/register_etDisplayName"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:background="@drawable/bg_rounded_edittext"
            android:hint="Enter your name"
            android:inputType="textPersonName"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/register_tvNameLabel"
            app:layout_constraintStart_toStartOf="@id/register_glStart"
            app:layout_constraintEnd_toEndOf="@id/register_glEnd" />

        <!-- Email Field -->
        <TextView
            android:id="@+id/register_tvEmailLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textColor="#424242"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/register_etDisplayName"
            app:layout_constraintStart_toStartOf="@id/register_glStart" />

        <EditText
            android:id="@+id/register_etEmail"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:background="@drawable/bg_rounded_edittext"
            android:hint="Enter your email"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/register_tvEmailLabel"
            app:layout_constraintStart_toStartOf="@id/register_glStart"
            app:layout_constraintEnd_toEndOf="@id/register_glEnd" />

        <!-- Password Field -->
        <TextView
            android:id="@+id/register_tvPasswordLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textColor="#424242"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/register_etEmail"
            app:layout_constraintStart_toStartOf="@id/register_glStart" />

        <EditText
            android:id="@+id/register_etPassword"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:background="@drawable/bg_rounded_edittext"
            android:hint="Enter your password"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/register_tvPasswordLabel"
            app:layout_constraintStart_toStartOf="@id/register_glStart"
            app:layout_constraintEnd_toEndOf="@id/register_glEnd" />

        <!-- Confirm Password Field -->
        <TextView
            android:id="@+id/register_tvConfirmPasswordLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Confirm Password"
            android:textColor="#424242"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/register_etPassword"
            app:layout_constraintStart_toStartOf="@id/register_glStart" />

        <EditText
            android:id="@+id/register_etConfirmPassword"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:background="@drawable/bg_rounded_edittext"
            android:hint="Confirm your password"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/register_tvConfirmPasswordLabel"
            app:layout_constraintStart_toStartOf="@id/register_glStart"
            app:layout_constraintEnd_toEndOf="@id/register_glEnd" />

        <!-- Buttons -->
        <Button
            android:id="@+id/register_btnRegister"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:text="Sign Up"
            android:textAllCaps="false"
            android:backgroundTint="#007ACC"
            android:textColor="@android:color/white"
            android:layout_marginTop="32dp"
            app:cornerRadius="8dp"
            app:layout_constraintTop_toBottomOf="@id/register_etConfirmPassword"
            app:layout_constraintStart_toStartOf="@id/register_glStart"
            app:layout_constraintEnd_toEndOf="@id/register_glEnd" />

        <Button
            android:id="@+id/register_btnGoToLogin"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:text="Back to Login"
            android:textAllCaps="false"
            android:backgroundTint="@android:color/white"
            android:textColor="#007ACC"
            android:layout_marginTop="12dp"
            app:strokeColor="#007ACC"
            app:strokeWidth="1dp"
            app:cornerRadius="8dp"
            app:layout_constraintTop_toBottomOf="@id/register_btnRegister"
            app:layout_constraintStart_toStartOf="@id/register_glStart"
            app:layout_constraintEnd_toEndOf="@id/register_glEnd" />

        <ProgressBar
            android:id="@+id/register_progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:indeterminateTint="#007ACC"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
